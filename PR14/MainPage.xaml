<Page x:Class="PR14.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MainPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <Button Content="Личный кабинет" Click="BtnProfile_Click" Margin="0,0,20,0"/>
            <TextBox Name="TxtSearch" Width="200" TextChanged="TxtSearch_TextChanged"/>
            <ComboBox Name="ComboSort" SelectionChanged="ComboSort_SelectionChanged" Width="150" Margin="10,0">
                <ComboBoxItem Content="Сортировка" IsSelected="True"/>
                <ComboBoxItem Content="По названию"/>
                <ComboBoxItem Content="По рейтингу"/>
            </ComboBox>
            <Button Content="Войти" Name="BtnLogin" Click="BtnLogin_Click" Margin="20,0"/>
        </StackPanel>

        <ListView Name="LViewMovies" Grid.Row="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="LViewMovies_MouseDoubleClick">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Width="200" Height="250">
                        <StackPanel>
                            <Image Source="{Binding ImagePath}" Height="150" Stretch="UniformToFill"/>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Margin="5"/>
                            <TextBlock Text="{Binding Rating, StringFormat=Рейтинг: {0}}" Margin="5"/>
                            <TextBlock Text="{Binding AgeRating, StringFormat={}{0}+}" Foreground="Red" Margin="5"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
<Page x:Class="PR14.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR14"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="ВХОД" FontSize="24" HorizontalAlignment="Center" Margin="10"/>

            <TextBlock Text="Логин:"/>
            <TextBox Name="TxtLogin" Margin="0,5,0,10" Height="25"/>

            <TextBlock Text="Пароль:"/>
            <PasswordBox Name="TxtPassword" Margin="0,5,0,20" Height="25"/>

            <Button Content="Войти" Click="BtnLogin_Click" Height="35" Background="LightBlue"/>
            <Button Content="Регистрация" Click="BtnReg_Click" Margin="0,10" Background="Transparent" BorderThickness="0" Foreground="Blue" Cursor="Hand"/>
            <Button Content="Назад" Click="BtnBack_Click" Background="Transparent" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Page>

<Window x:Class="PR15.SavedAssembliesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сохранённые сборки" Height="500" Width="900" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,15" LastChildFill="True">
            <Button Content="🡨 Назад" Padding="15,5" Background="LightGray" FontWeight="Bold" 
                    Click="BackButton_Click" DockPanel.Dock="Left"/>
            <TextBlock Text="Список сохранённых конфигураций ПК" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </DockPanel>

        <ListView x:Name="AssembliesListView" Grid.Row="1" BorderBrush="Silver" BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Автор сборки" DisplayMemberBinding="{Binding Author}" Width="150"/>
                    <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Name}" Width="200"/>

                    <GridViewColumn Header="Содержимое сборки" Width="500">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Contents}" TextWrapping="Wrap" Margin="0,5"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
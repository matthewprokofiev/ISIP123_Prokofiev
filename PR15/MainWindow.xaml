<Window x:Class="PR15.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Конфигуратор ПК 'Собери сам'" Height="750" Width="1100" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="HintTextBox" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Margin="5,2,0,0" 
                                       Foreground="Gray" IsHitTestVisible="False" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Доступные комплектующие" FontSize="22" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0" Margin="0,0,5,0" Padding="5" 
                             Tag="Поиск по названию..." Style="{StaticResource HintTextBox}" TextChanged="FilterChanged"/>
                    <ComboBox x:Name="ManufacturerFilter" Grid.Column="1" Margin="5,0,5,0" 
                              DisplayMemberPath="name" SelectionChanged="FilterChanged"/>
                    <Button Grid.Column="2" Content="Сбросить" Padding="10,5" Click="ResetFilters_Click"/>
                </Grid>
            </StackPanel>

            <ListView x:Name="PartsListView" Grid.Row="1" BorderBrush="LightGray" BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Фото" Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding ImagePath}" Width="40" Height="40" Stretch="Uniform"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Наименование" DisplayMemberBinding="{Binding Name}" Width="200"/>
                        <GridViewColumn Header="Производитель" DisplayMemberBinding="{Binding Manufacturer}" Width="120"/>
                        <GridViewColumn Header="Описание" DisplayMemberBinding="{Binding Description}" Width="200"/>
                        <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price, StringFormat={}{0:N0} ₽}" Width="90"/>
                        <GridViewColumn Header="Действие" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Выбрать" Click="AddToCart_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <Border Grid.Column="1" Background="#F4F4F4" Padding="15" BorderBrush="Silver" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Ваша конфигурация" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                <ListBox x:Name="SelectedPartsList" Grid.Row="1" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                <DockPanel LastChildFill="True">
                                    <Button Content="✕" DockPanel.Dock="Right" Foreground="Red" Background="Transparent" 
                                            BorderThickness="0" FontWeight="Bold" Click="RemoveFromCart_Click" Tag="{Binding}"/>
                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="0,15,0,0">
                    <Border Background="White" Padding="10" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="Статус совместимости:" FontWeight="Bold" FontSize="13"/>
                            <TextBlock x:Name="CompatibilityStatus" Text="Пусто" TextWrapping="Wrap" Margin="0,5,0,10"/>

                            <TextBlock x:Name="RequiredList" Text="Не хватает: " FontSize="11" Foreground="DarkRed" TextWrapping="Wrap"/>

                            <Separator Margin="0,10"/>
                            <DockPanel>
                                <TextBlock Text="ИТОГО:" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:Name="TotalPriceText" Text="0 ₽" FontSize="22" FontWeight="Bold" 
                                           Foreground="DarkGreen" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <TextBox x:Name="AssemblyNameBox" Margin="0,10,0,5" Padding="8" FontSize="14"
                             Tag="Введите название сборки..." Style="{StaticResource HintTextBox}" TextChanged="InputFields_TextChanged"/>

                    <TextBox x:Name="AuthorNameBox" Margin="0,0,0,10" Padding="8" FontSize="14"
                             Tag="Введите имя автора..." Style="{StaticResource HintTextBox}" TextChanged="InputFields_TextChanged"/>

                    <Button x:Name="SaveBtn" Content="СОХРАНИТЬ СБОРКУ" Height="50" IsEnabled="False"
        Foreground="White" FontSize="16" FontWeight="Bold" Click="SaveAssembly_Click" Margin="0,10,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FF2ECC71"/>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="LightGray"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
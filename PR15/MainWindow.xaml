<Window x:Class="PR15.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конфигуратор ПК 'Собери сам'" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Каталог комплектующих" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0" Margin="0,0,5,0" TextChanged="FilterChanged"/>
                    <ComboBox x:Name="ManufacturerFilter" Grid.Column="1" Margin="5,0,0,0" SelectionChanged="FilterChanged" DisplayMemberPath="name"/>
                    <Button Grid.Column="2" Content="Сброс" Margin="5,0,0,0" Click="ResetFilters_Click" Padding="10,0"/>
                </Grid>
            </StackPanel>

            <ListView x:Name="PartsListView" Grid.Row="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Фото" Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding ImagePath}" Width="40" Height="40"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Наименование" DisplayMemberBinding="{Binding Name}" Width="250"/>
                        <GridViewColumn Header="Производитель" DisplayMemberBinding="{Binding Manufacturer}" Width="120"/>
                        <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price, StringFormat={}{0:C}}" Width="100"/>
                        <GridViewColumn Header="Действие">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Добавить" Click="AddToCart_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <Border Grid.Column="1" Background="#F9F9F9" BorderBrush="LightGray" BorderThickness="1,0,0,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Ваша сборка" FontSize="18" FontWeight="Bold"/>
                    <Button Content="Посмотреть сохраненные" Margin="0,5,0,10" Click="ViewSaved_Click"/>
                </StackPanel>

                <ListBox x:Name="SelectedPartsList" Grid.Row="1" Margin="0,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="True" Width="280">
                                <Button Content="❌" DockPanel.Dock="Right" Click="RemoveFromCart_Click" Tag="{Binding}" Background="Transparent" BorderBrush="Transparent" Foreground="Red"/>
                                <TextBlock Text="{Binding Name}" TextWrapping="Wrap" FontSize="11"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border  Grid.Row="2" Background="White" Padding="10" BorderBrush="LightGray" BorderThickness="0,1,0,0">
                    <StackPanel>
                    <TextBlock Text="Проверка совместимости:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="CompatibilityStatus" Text="Ожидание выбора компонентов..." TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"/>

                    <Separator Margin="0,5"/>
                    <TextBlock x:Name="TotalPriceText" Text="Итого: 0,00 ₽" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,10"/>

                    <TextBox x:Name="AssemblyNameBox" Margin="0,5" Tag="Название сборки"/>
                    <TextBox x:Name="AuthorNameBox" Margin="0,5" Tag="Автор"/>
                    <Button Content="Сохранить сборку" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="SaveAssembly_Click"/>
                    </StackPanel>
               </Border>
            </Grid>
        </Border>
    </Grid>
</Window>